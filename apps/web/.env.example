# payClear web/app 빌드 환경변수 예시
# 이 파일을 복사해 .env / .env.production / .env.local 등으로 사용하세요.
# (.env* 는 .gitignore 처리되며, 이 .env.example 만 추적됩니다.)

# API base URL (빌드타임 주입)
# - 웹 빌드(기본): 아래 줄을 비워두거나 설정하지 않으면 상대경로 '/api/v1' 를 사용합니다.
#   같은 오리진에 배포되거나 Vite dev proxy(localhost:3910)를 사용할 때 적합합니다.
# - 안드로이드 앱 빌드: Railway 운영 도메인을 절대 URL 로 지정합니다(끝에 /api/v1 포함).
#
# 예) 앱 빌드 시:
# VITE_API_BASE=https://payclear-api.up.railway.app/api/v1
#
# 웹 빌드 시: (설정하지 않음 → '/api/v1' 상대경로 유지)
# VITE_API_BASE=

# FCM 푸시 (안드로이드 앱 빌드)
# google-services.json 이 android/app/ 에 있으면 cap:sync 가 자동으로 true 를 주입한다.
# 수동 빌드 시:
# VITE_FCM_ENABLED=true
