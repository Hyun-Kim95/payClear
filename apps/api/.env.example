# payClear API — copy to .env (do not commit .env)

PORT=3910

# PostgreSQL (ADR-002, local)
# 네이티브 Postgres (슈퍼유저로 DB 생성: npm run db:create)
DATABASE_URL=postgresql://postgres@localhost:5432/payclear
# 선택: scripts/setup-db.sql 로 payclear 롤 생성 시
# DATABASE_URL=postgresql://payclear:payclear@localhost:5432/payclear

# JWT (OAuth 완료 후 세션)
JWT_SECRET=change-me-in-local-dev-only

# OAuth — register redirect URIs with each provider
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=

# CORS / callbacks
WEB_ORIGIN=http://localhost:5173
API_PUBLIC_URL=http://localhost:3910

# Dev only — remove when SNS login ships
ALLOW_DEV_TOKEN=true

# Email verify: log token to console (local dev)
EMAIL_VERIFY_DEV=true

# Web Push (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:demo@payclear.local

# Due reminders — email (optional; local: log only)
NOTIFY_EMAIL_DEV=log
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@payclear.local

# Dev: API starts 60s notify dry-run interval when true
NOTIFY_CRON_DEV=false
