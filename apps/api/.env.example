# payClear API — .env 예시 (실제 .env는 커밋하지 말 것)
# 로컬: 이 파일을 .env로 복사 후 값 채우기. 운영: Railway 변수로 주입.
# 실제 시크릿(JWT_SECRET, OAuth secret, Firebase 키 등)은 여기 넣지 말 것(플레이스홀더만).

# ── 서버 ─────────────────────────────────────────────
# 로컬 기본 3910. 운영(Railway)은 PORT를 자동 주입하므로 설정 불필요.
PORT=3910

# ── PostgreSQL ──────────────────────────────────────
# 로컬: 네이티브 Postgres (npm run db:create 로 DB 생성)
DATABASE_URL=postgresql://postgres@localhost:5432/payclear
# 운영(Railway): Postgres 플러그인이 DATABASE_URL 자동 주입(내부 네트워크).
# 공개(외부 프록시) DB URL을 쓸 때만 SSL 필요 → 아래 둘 중 하나를 true/require.
# DATABASE_SSL=true
# PGSSLMODE=require

# ── JWT(OAuth 세션) ─────────────────────────────────
# 운영: 강한 랜덤 값으로 재발급(로컬 값 회전). 예: openssl rand -base64 32
JWT_SECRET=replace-with-strong-random-secret

# ── OAuth ───────────────────────────────────────────
# 각 콘솔에 redirect URI 등록: {API_PUBLIC_URL}/api/v1/auth/{provider}/callback
# 운영 도메인을 redirect 허용 목록에 추가할 것. 운영은 재발급 권장.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=

# ── CORS / 콜백 / 딥링크 ────────────────────────────
# WEB_ORIGIN: 웹 OAuth redirect 대상(웹 호스팅 시 운영 웹 오리진).
WEB_ORIGIN=http://localhost:5173
# API_PUBLIC_URL: OAuth redirect_uri 구성에 사용. 운영=https://<railway-domain>
API_PUBLIC_URL=http://localhost:3910
# 앱 로그인은 ?client=app → payclear://auth/callback 딥링크로 분기(서버 추가 변수 없음).

# ── 개발 전용 플래그(운영은 반드시 false) ───────────
# ALLOW_DEV_TOKEN: Bearer dev-token → user-1 허용. 운영 필수 false.
ALLOW_DEV_TOKEN=true
# EMAIL_VERIFY_DEV: 인증 토큰 콘솔 로그. 미설정 시 ALLOW_DEV_TOKEN 값을 따름. 운영 필수 false.
EMAIL_VERIFY_DEV=true
# SEED_DEMO: 데모 데이터 시드. 로컬 편의 시 true, 운영 필수 false(미설정=off).
SEED_DEMO=true

# ── Web Push (선택) ─────────────────────────────────
# npx web-push generate-vapid-keys 로 발급. 미설정 시 web-push skip.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:demo@payclear.local

# ── FCM (안드로이드 푸시, 선택) ─────────────────────
# 자격증명 미설정 시 FCM 전송 skip(배포·동작에 지장 없음).
# 방법 1: 서비스계정 JSON 전체를 한 줄 문자열로.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
# 방법 2: 개별 필드(PRIVATE_KEY는 \n 이스케이프 허용).
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ── 이메일 리마인더 (선택) ──────────────────────────
# NOTIFY_EMAIL_DEV=log 면 콘솔 로그만. 운영은 SMTP_* 설정.
NOTIFY_EMAIL_DEV=log
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@payclear.local

# ── 개발 편의 ───────────────────────────────────────
# true면 부팅 후 60초마다 리마인더 dry-run.
NOTIFY_CRON_DEV=false
